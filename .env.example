# Copy to .env and fill in. Never commit the .env file itself.

# Telegram — register a bot via @BotFather on Telegram, paste the token here.
# OWNER_CHAT_ID is your numeric chat id (DM @userinfobot to find it).
TELEGRAM_BOT_TOKEN=
OWNER_CHAT_ID=

# Friends you want to share the bot with — comma-separated chat ids.
# Owner is auto-included; this is just additional users. The bot will
# politely reject anyone not on this allowlist and tell them their chat id
# so they can ask to be added. Leave empty for solo use.
# AUTHORIZED_CHAT_IDS=12345678,87654321

# LLM — any OpenAI-compatible /v1 endpoint. Defaults assume local Ollama.
# See docs/backends.md for LM Studio, llama.cpp, MLX, hosted-API setups.
# (For back-compat, OLLAMA_URL / OLLAMA_MODEL / OLLAMA_API_KEY also work.)
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen3:30b-a3b-instruct-2507-q4_K_M
# OpenAI-compatible endpoints don't require an API key for Ollama; some
# clients still demand the field be set. Any non-empty string works.
LLM_API_KEY=ollama

# Bluesky — only needed if a bsky:* source is enabled in preferences.yaml.
# Use an app password from https://bsky.app/settings/app-passwords (NOT your main password).
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# GitHub — optional. Without a token, github:* sources poll anonymously
# (60 requests/hour, fine for ~5 repos at hourly cadence). Set a token to
# raise the limit to 5000/h. Generate at https://github.com/settings/tokens
# (no scopes needed for public repos).
# GITHUB_TOKEN=

# Storage — SQLite path. Default is fine; override if you want it elsewhere.
DB_PATH=./sift.db

# Path to the user-editable preferences file.
PREFERENCES_PATH=./preferences.yaml
